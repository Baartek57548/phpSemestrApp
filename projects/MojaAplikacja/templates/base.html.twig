<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Moj Blog kulinarny{% endblock %}</title>
        <style>
            body {
                margin: 0;
                font-family: Arial, sans-serif;
                background: #f5f5f5;
                color: #222;
            }

            header,
            main,
            footer {
                max-width: 760px;
                margin: 0 auto;
                padding: 16px;
            }

            header {
                background: #ffffff;
                border-bottom: 1px solid #ddd;
            }

            main {
                min-height: 70vh;
            }

            article,
            .card {
                background: #ffffff;
                padding: 16px;
                margin-bottom: 16px;
                border: 1px solid #ddd;
            }

            .flash-success {
                background: #e8f7ee;
                border: 1px solid #86d19d;
                color: #1e6b36;
                padding: 12px 16px;
                margin-bottom: 16px;
            }

            .flash-error {
                background: #fdecec;
                border: 1px solid #e2a7a7;
                color: #8a1f1f;
                padding: 12px 16px;
                margin-bottom: 16px;
            }

            .form-panel {
                background: #ffffff;
                padding: 16px;
                margin-bottom: 16px;
                border: 1px solid #ddd;
            }

            .form-row {
                margin-bottom: 14px;
            }

            label {
                display: block;
                font-weight: 700;
                margin-bottom: 6px;
            }

            input,
            textarea,
            select,
            button {
                width: 100%;
                box-sizing: border-box;
                padding: 10px 12px;
                border: 1px solid #c7c7c7;
                border-radius: 4px;
                font: inherit;
            }

            button {
                background: #0a58ca;
                color: #ffffff;
                border: none;
                cursor: pointer;
                font-weight: 700;
            }

            button:hover {
                background: #084298;
            }

            .form-errors {
                color: #a40000;
                margin-top: 6px;
                font-size: 0.95rem;
            }

            .comment-meta {
                font-size: 0.95rem;
                color: #555;
                margin-bottom: 8px;
            }

            a {
                color: #0a58ca;
                text-decoration: none;
            }

            a:hover {
                text-decoration: underline;
            }

            h1,
            h2,
            p {
                margin-top: 0;
            }
        </style>
    </head>
    <body>
        <header>
            <h1><a href="{{ path('blog_index') }}">Moj Blog kulinarny</a></h1>
            <p>Strona stworzona z myślą o pasjonatach kulinarnych</p>
            <p>
                {% if app.user %}
                    Zalogowany: <strong>{{ app.user.userIdentifier }}</strong>
                    {% if is_granted('ROLE_ADMIN') %}(admin){% endif %}
                    {% if is_granted('ROLE_ADMIN') %}
                        | <a href="{{ path('admin_index') }}">Panel admin</a>
                    {% endif %}
                    | <a href="{{ path('app_logout') }}">Wyloguj</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Zaloguj</a>
                    | <a href="{{ path('app_register') }}">Zarejestruj</a>
                {% endif %}
            </p>
        </header>

        <main>
            {% for message in app.flashes('success') %}
                <div class="flash-success">{{ message }}</div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="flash-error">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer>
        </footer>
    </body>
</html>
